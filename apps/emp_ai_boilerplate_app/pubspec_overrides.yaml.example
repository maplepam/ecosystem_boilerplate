# Copy to `pubspec_overrides.yaml` (gitignored) for local development only — never commit.
#
# --- Option A: local ecosystem-platform clone (sibling of boilerplate) ---
# Override all five platform packages so Pub does not mix submodule + alternate path.
#
# dependency_overrides:
#   emp_ai_foundation:
#     path: ../../../ecosystem-platform/packages/emp_ai_foundation
#   emp_ai_core:
#     path: ../../../ecosystem-platform/packages/emp_ai_core
#   emp_ai_ds_northstar:
#     path: ../../../ecosystem-platform/packages/emp_ai_ds_northstar
#   emp_ai_ds_widgets:
#     path: ../../../ecosystem-platform/packages/emp_ai_ds_widgets
#   emp_ai_app_shell:
#     path: ../../../ecosystem-platform/packages/emp_ai_app_shell
#
# --- Option B: point at in-repo submodule paths (from this app directory) ---
# Same as committed pubspec, but useful to uncomment one package while testing a submodule branch.
#
# dependency_overrides:
#   emp_ai_core:
#     path: ../../packages/ecosystem-platform/packages/emp_ai_core
#
# --- Option C: local auth clone (optional) ---
# dependency_overrides:
#   emp_ai_auth:
#     path: /absolute/path/to/emp-ai-flutter-auth
#   emp_ai_ds:
#     path: /absolute/path/to/emp_ai_ds
